# Claude Code local settings (machine-specific permission allowlist)
.claude/settings.local.json

# Claude Code project guidance — keep local only, do not publish
CLAUDE.md

# Keep local only, do not publish
LICENSE

# Internal/confidential company drawings — never publish
*.pdf
input_doc/*.pdf

# Generated Donut training data / crops (derived from confidential drawings)
datasets/donut_anno/
patches/
**/_crops/
**/_pages/

# Python
__pycache__/
*.py[cod]
.ipynb_checkpoints/

# YOLO training runs (weights / logs are large)
yolo_obb_drawing/
yolo_layout_drawing/
*.pt
*.cache                 # ultralytics label caches (datasets/**/labels/*.cache)

# Dataset binaries (keep folder structure via .gitkeep, not the images/labels)
datasets/drawing_obb/images/train/*
datasets/drawing_obb/images/val/*
datasets/drawing_obb/labels/train/*
datasets/drawing_obb/labels/val/*
datasets/drawing_layout/images/train/*
datasets/drawing_layout/images/val/*
datasets/drawing_layout/labels/train/*
datasets/drawing_layout/labels/val/*
!**/.gitkeep
